# =============================================================================
# Пример конфигурации интеграционного сервиса MAX-бота
# Скопируйте в .env и заполните реальными значениями
# =============================================================================

# --- Общие ---
APP_NAME=max-bot-nomenclature
LOG_LEVEL=INFO
POLLING_ENABLED=true
POLLING_INTERVAL_SEC=2

# --- PostgreSQL ---
# Для Docker Compose используйте хост db:
DATABASE_URL=postgresql+psycopg2://bot:bot@db:5432/botdb
# Для локального запуска без Docker:
# DATABASE_URL=postgresql+psycopg2://bot:bot@localhost:5432/botdb

# --- MAX Bot API (https://dev.max.ru/docs-api) ---
MAX_BOT_TOKEN=your_max_bot_token_here
MAX_API_BASE_URL=https://platform-api.max.ru
# Секрет для проверки webhook (заголовок X-Max-Bot-Api-Secret)
MAX_WEBHOOK_SECRET=

# --- Telegram (опционально) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Vision / Yandex Cloud (основной провайдер) ---
VISION_PROVIDER=yandex

# API-ключ сервисного аккаунта Yandex Cloud (рекомендуется для Docker)
# Роли: ai.vision.user, ai.languageModels.user
YANDEX_API_KEY=your_yandex_api_key_here
# Альтернатива API-ключу — IAM-токен (короткоживущий, обновляется вручную/скриптом)
YANDEX_IAM_TOKEN=
# ID каталога Yandex Cloud (folder_id)
YANDEX_FOLDER_ID=b1gxxxxxxxxxxxxxxxxxx
YANDEX_VISION_URL=https://vision.api.cloud.yandex.net/vision/v1/batchAnalyze
YANDEX_GPT_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
# Модель YandexGPT для структурирования OCR-текста
YANDEX_GPT_MODEL=yandexgpt
# Полный URI модели (если задан — переопределяет YANDEX_GPT_MODEL)
# YANDEX_GPT_MODEL_URI=gpt://b1g.../yandexgpt/latest
YANDEX_GPT_MODEL_URI=
# Обогащать OCR через YandexGPT (description, tags, brand)
YANDEX_USE_GPT_ENRICHMENT=true
YANDEX_OCR_LANGUAGES=ru,en

# --- OpenAI Vision (только если VISION_PROVIDER=openai) ---
VISION_API_URL=https://api.openai.com/v1/chat/completions
VISION_API_KEY=
VISION_MODEL=gpt-4o-mini

# --- 1С:УНФ HTTP API ---
# URL публикации информационной базы (без завершающего слэша)
ONEC_BASE_URL=http://localhost/unf/ru
ONEC_USERNAME=Admin
ONEC_PASSWORD=
ONEC_SEARCH_LIMIT=5
ONEC_TIMEOUT_SEC=30

# --- Авторизация по телефону пользователя 1С ---
# true — доступ только после проверки номера в справочнике Пользователи
AUTH_ENABLED=false
