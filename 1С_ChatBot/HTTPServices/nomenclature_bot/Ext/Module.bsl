Функция ПреобразоватьЛимит(ЛимитСтрока)
	
	Лимит = 5;
	Если Не ЗначениеЗаполнено(ЛимитСтрока) Тогда
		Возврат Лимит;
	КонецЕсли;
	
	Попытка
		Лимит = Число(ЛимитСтрока);
	Исключение
		Лимит = 5;
	КонецПопытки;
	
	Возврат Лимит;
	
КонецФункции

Функция ПолучитьПараметрЗапроса(Запрос, ИмяПараметра, ЗначениеПоУмолчанию = "")
	
	ЗначениеПараметра = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
	Если ЗначениеПараметра = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Возврат ЗначениеПараметра;
	
КонецФункции

Функция ОтветJSON(КодСостояния, Данные)
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(ЧБ_НоменклатураБотAPI.ЗаписатьJSONВСтроку(Данные), КодировкаТекста.UTF8);
	Возврат Ответ;
	
КонецФункции

Функция ОтветОшибки(КодСостояния, ТекстОшибки)
	
	ДанныеОшибки = Новый Структура("error", ТекстОшибки);
	Возврат ОтветJSON(КодСостояния, ДанныеОшибки);
	
КонецФункции

Функция ОтветИсключения(ТекстОшибки, ИмяОперации)
	
	ЗаписьЖурналаРегистрации(
		СобытиеЖурналаРегистрации() + "." + ИмяОперации,
		УровеньЖурналаРегистрации.Ошибка,,,
		ТекстОшибки);
	
	Возврат ОтветОшибки(500, ТекстОшибки);
	
КонецФункции

Функция СобратьПараметрыПоискаИзЗапроса(Запрос)
	
	ПараметрыПоиска = Новый Структура("barcode, article, tokens, q", "", "", Новый Массив, "");
	ПараметрыПоиска.barcode = ПолучитьПараметрЗапроса(Запрос, "barcode");
	ПараметрыПоиска.article = ПолучитьПараметрЗапроса(Запрос, "article");
	ПараметрыПоиска.q = ПолучитьПараметрЗапроса(Запрос, "q");
	
	ТокеныСтрока = ПолучитьПараметрЗапроса(Запрос, "tokens");
	Если ЗначениеЗаполнено(ТокеныСтрока) Тогда
		ПараметрыПоиска.tokens = СтрРазделить(ТокеныСтрока, ",", Ложь);
	КонецЕсли;
	
	Возврат ПараметрыПоиска;
	
КонецФункции

Функция СобратьПараметрыПоискаИзJSON(ДанныеJSON)
	
	ПараметрыПоиска = Новый Структура("barcode, article, tokens, q", "", "", Новый Массив, "");
	ПараметрыПоиска.barcode = ПолучитьЗначениеJSON(ДанныеJSON, "barcode");
	ПараметрыПоиска.article = ПолучитьЗначениеJSON(ДанныеJSON, "article");
	ПараметрыПоиска.q = ПолучитьЗначениеJSON(ДанныеJSON, "q");
	
	Токены = ПолучитьЗначениеJSON(ДанныеJSON, "tokens");
	Если ТипЗнч(Токены) = Тип("Массив") Тогда
		ПараметрыПоиска.tokens = Токены;
	ИначеЕсли ЗначениеЗаполнено(Токены) Тогда
		ПараметрыПоиска.tokens = СтрРазделить(Строка(Токены), ",", Ложь);
	КонецЕсли;
	
	Возврат ПараметрыПоиска;
	
КонецФункции

Функция ПолучитьЗначениеJSON(ДанныеJSON, ИмяПоля, ЗначениеПоУмолчанию = "")
	
	Если ТипЗнч(ДанныеJSON) = Тип("Соответствие") Тогда
		Значение = ДанныеJSON.Получить(ИмяПоля);
	ИначеЕсли ТипЗнч(ДанныеJSON) = Тип("Структура") Тогда
		
		Если Не ДанныеJSON.Свойство(ИмяПоля) Тогда
			Возврат ЗначениеПоУмолчанию;
		КонецЕсли;
		
		Если ИмяПоля = "barcode" Тогда
			Значение = ДанныеJSON.barcode;
		ИначеЕсли ИмяПоля = "article" Тогда
			Значение = ДанныеJSON.article;
		ИначеЕсли ИмяПоля = "q" Тогда
			Значение = ДанныеJSON.q;
		ИначеЕсли ИмяПоля = "tokens" Тогда
			Значение = ДанныеJSON.tokens;
		ИначеЕсли ИмяПоля = "limit" Тогда
			Значение = ДанныеJSON.limit;
		ИначеЕсли ИмяПоля = "phone" Тогда
			Значение = ДанныеJSON.phone;
		Иначе
			Возврат ЗначениеПоУмолчанию;
		КонецЕсли;
		
	Иначе
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Функция ПараметрыПоискаЗаполнены(ПараметрыПоиска)
	
	Если ЗначениеЗаполнено(ПараметрыПоиска.barcode) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыПоиска.article) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ПараметрыПоиска.tokens.Количество() > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыПоиска.q) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти
