#Область СлужебныеПроцедурыИФункции

Функция searchGET(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		Лимит = ПреобразоватьЛимит(ПолучитьПараметрЗапроса(Запрос, "limit", "5"));
		ПараметрыПоиска = СобратьПараметрыПоискаИзЗапроса(Запрос);
		
		Если Не ПараметрыПоискаЗаполнены(ПараметрыПоиска) Тогда
			Возврат ОтветОшибки(400, НСтр("ru = 'Не указан параметр q или параметры barcode/article/tokens.'"));
		КонецЕсли;
		
		Данные = ЧБ_НоменклатураБотAPI.ПоискНоменклатурыРасширенный(ПараметрыПоиска, Лимит);
		Возврат ОтветJSON(200, Данные);
		
	Исключение
		
		Возврат ОтветИсключения(ОписаниеОшибки(), "search");
		
	КонецПопытки;
	
КонецФункции

Функция searchPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		ТелоJSON = Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		Если Не ЗначениеЗаполнено(ТелоJSON) Тогда
			Возврат ОтветОшибки(400, НСтр("ru = 'Пустое тело запроса.'"));
		КонецЕсли;
		
		ДанныеЗапроса = ЧБ_НоменклатураБотAPI.ПрочитатьJSONИзСтроки(ТелоJSON, Истина);
		ПараметрыПоиска = СобратьПараметрыПоискаИзJSON(ДанныеЗапроса);
		Лимит = ПреобразоватьЛимит(ПолучитьЗначениеJSON(ДанныеЗапроса, "limit", "5"));
		
		Если Не ПараметрыПоискаЗаполнены(ПараметрыПоиска) Тогда
			Возврат ОтветОшибки(400, НСтр("ru = 'Укажите barcode, article, tokens или q.'"));
		КонецЕсли;
		
		Данные = ЧБ_НоменклатураБотAPI.ПоискНоменклатурыРасширенный(ПараметрыПоиска, Лимит);
		Возврат ОтветJSON(200, Данные);
		
	Исключение
		
		Возврат ОтветИсключения(ОписаниеОшибки(), "search");
		
	КонецПопытки;
	
КонецФункции

Функция stockGET(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		СтрокаСсылка = ПолучитьПараметрЗапроса(Запрос, "ref");
		Склад = ПолучитьПараметрЗапроса(Запрос, "warehouse");
		
		Если Не ЗначениеЗаполнено(СтрокаСсылка) Тогда
			Возврат ОтветОшибки(400, НСтр("ru = 'Не указан параметр ref.'"));
		КонецЕсли;
		
		СсылкаНоменклатуры = ЧБ_НоменклатураБотAPI.СсылкаПоУникальномуИдентификатору(СтрокаСсылка);
		Если Не ЗначениеЗаполнено(СсылкаНоменклатуры)
			Или Не ОбщегоНазначения.СсылкаСуществует(СсылкаНоменклатуры) Тогда
			Возврат ОтветОшибки(404, НСтр("ru = 'Номенклатура не найдена.'"));
		КонецЕсли;
		
		Данные = ЧБ_НоменклатураБотAPI.ПолучитьОстатки(СсылкаНоменклатуры, Склад);
		Возврат ОтветJSON(200, Данные);
		
	Исключение
		
		Возврат ОтветИсключения(ОписаниеОшибки(), "stock");
		
	КонецПопытки;
	
КонецФункции

