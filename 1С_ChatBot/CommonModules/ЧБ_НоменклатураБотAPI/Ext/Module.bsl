Функция НормализоватьСтрокуПоиска(Знач СтрокаПоиска)
	
	СтрокаПоиска = СокрЛП(СтрокаПоиска);
	Если Не ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Возврат "";
	КонецЕсли;
	
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, Символ(160), " ");
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, "ё", "е");
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, "Ё", "Е");
	
	Пока СтрНайти(СтрокаПоиска, "  ") > 0 Цикл
		СтрокаПоиска = СтрЗаменить(СтрокаПоиска, "  ", " ");
	КонецЦикла;
	
	Возврат СтрокаПоиска;
	
КонецФункции

Функция ТолькоЦифрыШтрихкода(Знач Значение)
	
	Значение = СокрЛП(Значение);
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат "";
	КонецЕсли;
	
	Результат = "";
	Для Индекс = 1 По СтрДлина(Значение) Цикл
		Символ = Сред(Значение, Индекс, 1);
		Если Символ >= "0" И Символ <= "9" Тогда
			Результат = Результат + Символ;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПохожеНаШтрихкод(Знач Значение)
	
	Цифры = ТолькоЦифрыШтрихкода(Значение);
	Возврат СтрДлина(Цифры) >= 8 И СтрДлина(Цифры) <= 14;
	
КонецФункции

Функция ЭтоСтопСлово(Знач Слово)
	
