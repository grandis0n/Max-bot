Функция РазложитьСтрокуНаТокены(Знач СтрокаПоиска)
	
	Результат = Новый Массив;
	СтрокаПоиска = НормализоватьСтрокуПоиска(СтрокаПоиска);
	Если Не ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, ",", " ");
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, ";", " ");
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, "|", " ");
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, "/", " ");
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, "\", " ");
	
	Части = СтрРазделить(СтрокаПоиска, " ", Ложь);
	УжеДобавлено = Новый Соответствие;
	
	Для Каждого Часть Из Части Цикл
		
		Токен = НормализоватьСтрокуПоиска(Часть);
		Если Не ЗначениеЗаполнено(Токен) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПохожеНаШтрихкод(Токен) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрДлина(Токен) < 2 Или ЭтоСтопСлово(Токен) Тогда
			Продолжить;
		КонецЕсли;
		
		Ключ = НРег(Токен);
		Если УжеДобавлено.Получить(Ключ) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		УжеДобавлено.Вставить(Ключ, Истина);
		Результат.Добавить(Токен);
		
		Если Результат.Количество() >= 8 Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция НормализоватьМассивТокенов(Токены)
	
	Результат = Новый Массив;
	УжеДобавлено = Новый Соответствие;
	
	Если ТипЗнч(Токены) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Токен Из Токены Цикл
		
		Для Каждого НормализованныйТокен Из РазложитьСтрокуНаТокены(Строка(Токен)) Цикл
			
			Ключ = НРег(НормализованныйТокен);
			Если УжеДобавлено.Получить(Ключ) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			УжеДобавлено.Вставить(Ключ, Истина);
			Результат.Добавить(НормализованныйТокен);
			
			Если Результат.Количество() >= 8 Тогда
				Возврат Результат;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьКандидата(Кандидаты, Ссылка, Наименование, Артикул, Штрихкод, Баллы)
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	Ключ = УникальныйИдентификаторСсылки(Ссылка);
	Если Не ЗначениеЗаполнено(Ключ) Тогда
		Возврат;
	КонецЕсли;
	
	Существующий = Кандидаты.Получить(Ключ);
	Если Существующий = Неопределено Тогда
		
		Элемент = Новый Структура;
		Элемент.Вставить("ref", Ключ);
		Элемент.Вставить("name", Наименование);
		Элемент.Вставить("article", Артикул);
		Элемент.Вставить("barcode", Штрихкод);
		Элемент.Вставить("score", Баллы);
		Кандидаты.Вставить(Ключ, Элемент);
		
	Иначе
		
		Существующий.score = Макс(Существующий.score, Баллы);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКандидатовПоШтрихкоду(Кандидаты, Штрихкод, Баллы)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.Наименование КАК Наименование,
		|	Номенклатура.Артикул КАК Артикул,
		|	Номенклатура.Штрихкод КАК Штрихкод
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ЭтоГруппа
		|	И НЕ Номенклатура.ПометкаУдаления
		|	И НЕ Номенклатура.Недействителен
		|	И Номенклатура.Штрихкод = &Штрихкод
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	Штрихкоды.Номенклатура,
		|	Штрихкоды.Номенклатура.Наименование,
		|	Штрихкоды.Номенклатура.Артикул,
		|	Штрихкоды.Штрихкод
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
		|ГДЕ
		|	Штрихкоды.Штрихкод = &Штрихкод
		|	И НЕ Штрихкоды.Номенклатура.ЭтоГруппа
		|	И НЕ Штрихкоды.Номенклатура.ПометкаУдаления
		|	И НЕ Штрихкоды.Номенклатура.Недействителен";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДобавитьКандидата(
			Кандидаты,
			Выборка.Ссылка,
			Выборка.Наименование,
			Выборка.Артикул,
			Выборка.Штрихкод,
			Баллы);
	КонецЦикла;
	
КонецПроцедуры

