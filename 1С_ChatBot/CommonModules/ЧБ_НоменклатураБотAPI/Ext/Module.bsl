Процедура ДобавитьКандидатовПоПодстроке(Кандидаты, Подстрока, Баллы)
	
	Шаблон = "%" + Подстрока + "%";
	ШаблонНачала = Подстрока + "%";
	ЛимитВыборки = 30;
	ТекстЛимита = Формат(ЛимитВыборки, "ЧГ=0");
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(
		"ВЫБРАТЬ ПЕРВЫЕ %1
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.Наименование КАК Наименование,
		|	Номенклатура.Артикул КАК Артикул,
		|	Номенклатура.Штрихкод КАК Штрихкод,
		|	ВЫБОР
		|		КОГДА Номенклатура.Наименование ПОДОБНО &ШаблонНачала
		|			ТОГДА 10
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК БонусНачала
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ЭтоГруппа
		|	И НЕ Номенклатура.ПометкаУдаления
		|	И НЕ Номенклатура.Недействителен
		|	И (Номенклатура.Наименование ПОДОБНО &Шаблон
		|		ИЛИ Номенклатура.НаименованиеПолное ПОДОБНО &Шаблон
		|		ИЛИ Номенклатура.Артикул ПОДОБНО &Шаблон
		|		ИЛИ Номенклатура.Комментарий ПОДОБНО &Шаблон)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ ПЕРВЫЕ %1
		|	Характеристики.Владелец,
		|	Характеристики.Владелец.Наименование,
		|	Характеристики.Артикул,
		|	Характеристики.Владелец.Штрихкод,
		|	0
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК Характеристики
		|ГДЕ
		|	НЕ Характеристики.ПометкаУдаления
		|	И НЕ Характеристики.Недействителен
		|	И НЕ Характеристики.Владелец.ЭтоГруппа
		|	И НЕ Характеристики.Владелец.ПометкаУдаления
		|	И НЕ Характеристики.Владелец.Недействителен
		|	И (Характеристики.Наименование ПОДОБНО &Шаблон
		|		ИЛИ Характеристики.Артикул ПОДОБНО &Шаблон)",
		ТекстЛимита);
	
	Запрос.УстановитьПараметр("Шаблон", Шаблон);
	Запрос.УстановитьПараметр("ШаблонНачала", ШаблонНачала);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ИтоговыеБаллы = Баллы + Выборка.БонусНачала;
		ДобавитьКандидата(
			Кандидаты,
			Выборка.Ссылка,
			Выборка.Наименование,
			Выборка.Артикул,
			Выборка.Штрихкод,
			ИтоговыеБаллы);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СформироватьСписокКандидатов(Кандидаты, Лимит)
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("ref");
	Таблица.Колонки.Добавить("name");
	Таблица.Колонки.Добавить("article");
	Таблица.Колонки.Добавить("barcode");
	Таблица.Колонки.Добавить("score", Новый ОписаниеТипов("Число"));
	
	Для Каждого КлючИЗначение Из Кандидаты Цикл
		
		Кандидат = КлючИЗначение.Значение;
		СтрокаТаблицы = Таблица.Добавить();
		СтрокаТаблицы.ref = Кандидат.ref;
		СтрокаТаблицы.name = Кандидат.name;
		СтрокаТаблицы.article = Кандидат.article;
		СтрокаТаблицы.barcode = Кандидат.barcode;
		СтрокаТаблицы.score = Кандидат.score;
		
	КонецЦикла;
	
	Таблица.Сортировать("score Убыв, name");
	
	Результат = Новый Массив;
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Элемент = Новый Структура;
		Элемент.Вставить("ref", СтрокаТаблицы.ref);
		Элемент.Вставить("name", СтрокаТаблицы.name);
		Элемент.Вставить("article", СтрокаТаблицы.article);
		Элемент.Вставить("barcode", СтрокаТаблицы.barcode);
		Элемент.Вставить("score", СтрокаТаблицы.score);
		Результат.Добавить(Элемент);
		
		Если Результат.Количество() >= Лимит Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ТипСодержимогоПоРасширению(Знач Расширение)
	
	Расширение = НРег(СокрЛП(СтрЗаменить(Расширение, ".", "")));
	
	Если Расширение = "jpg" Или Расширение = "jpeg" Тогда
		Возврат "image/jpeg";
	ИначеЕсли Расширение = "png" Тогда
		Возврат "image/png";
	ИначеЕсли Расширение = "gif" Тогда
		Возврат "image/gif";
	ИначеЕсли Расширение = "webp" Тогда
		Возврат "image/webp";
	ИначеЕсли Расширение = "bmp" Тогда
		Возврат "image/bmp";
	КонецЕсли;
	
	Возврат "application/octet-stream";
	
КонецФункции

Функция НайтиСтруктурнуюЕдиницу(Знач Склад)
	
	Склад = СокрЛП(Склад);
	Если Не ЗначениеЗаполнено(Склад) Тогда
		Возврат Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	КонецЕсли;
	
	Попытка
		УникальныйИдентификатор = Новый УникальныйИдентификатор(Склад);
		Ссылка = Справочники.СтруктурныеЕдиницы.ПолучитьСсылку(УникальныйИдентификатор);
		Если ОбщегоНазначения.СсылкаСуществует(Ссылка) Тогда
			Возврат Ссылка;
		КонецЕсли;
	Исключение
		// Не UUID — ищем по наименованию.
	КонецПопытки;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|ГДЕ
		|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
		|	И СтруктурныеЕдиницы.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", Склад);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	
КонецФункции

Функция ПоисковоеВыражениеТелефона(НомерТелефона)
	
	ЦифрыТелефона = ТолькоЦифрыТелефона(НомерТелефона);
	Если Не ЗначениеЗаполнено(ЦифрыТелефона) Тогда
		Возврат "";
	КонецЕсли;
	
	ПоисковоеВыражение = ЦифрыТелефона + "%";
	Если СтрНачинаетсяС(ПоисковоеВыражение, "7") Или СтрНачинаетсяС(ПоисковоеВыражение, "8") Тогда
		ПоисковоеВыражение = "[78]" + Сред(ПоисковоеВыражение, 2);
	КонецЕсли;
	
	Возврат ПоисковоеВыражение;
	
КонецФункции

Функция ТолькоЦифрыТелефона(НомерТелефона)
	
	Результат = "";
	Для Индекс = 1 По СтрДлина(НомерТелефона) Цикл
		
		Символ = Сред(НомерТелефона, Индекс, 1);
		Если Символ >= "0" И Символ <= "9" Тогда
			Результат = Результат + Символ;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПоисковоеВыражениеТелефонаБезКода(НомерТелефона)
	
	ЦифрыТелефона = ТолькоЦифрыТелефона(НомерТелефона);
	Если СтрДлина(ЦифрыТелефона) < 10 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат "%" + Прав(ЦифрыТелефона, 10) + "%";
	
КонецФункции

Функция НайтиПользователяПоТелефону(НомерТелефона)
	
	ПоисковоеВыражение = ПоисковоеВыражениеТелефона(НомерТелефона);
	Если Не ЗначениеЗаполнено(ПоисковоеВыражение) Тогда
		Возврат Справочники.Пользователи.ПустаяСсылка();
	КонецЕсли;
	
	ПоискБезКода = ПоисковоеВыражениеТелефонаБезКода(НомерТелефона);
	Если Не ЗначениеЗаполнено(ПоискБезКода) Тогда
		ПоискБезКода = "%";
	КонецЕсли;
	
	ПустойИдентификатор = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Пользователи.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Пользователи.КонтактнаяИнформация КАК КИПользователя
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
		|		ПО КИПользователя.Ссылка = Пользователи.Ссылка
		|ГДЕ
		|	НЕ Пользователи.ПометкаУдаления
		|	И Пользователи.Недействителен = ЛОЖЬ
		|	И Пользователи.Служебный = ЛОЖЬ
		|	И Пользователи.ИдентификаторПользователяИБ <> &ПустойИдентификатор
		|	И КИПользователя.Тип = &ТипТелефон
		|	И (КИПользователя.НомерТелефона ПОДОБНО &ПоисковоеВыражение
		|		ИЛИ КИПользователя.НомерТелефонаБезКодов ПОДОБНО &ПоисковоеВыражениеБезКода)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Пользователи.Наименование";
	
	Запрос.УстановитьПараметр("ТипТелефон", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("ПоисковоеВыражение", ПоисковоеВыражение);
	Запрос.УстановитьПараметр("ПоисковоеВыражениеБезКода", ПоискБезКода);
	Запрос.УстановитьПараметр("ПустойИдентификатор", ПустойИдентификатор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Пользователи.ПустаяСсылка();
	
КонецФункции

#КонецОбласти
