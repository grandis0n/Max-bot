// Возвращает строковое представление UUID ссылки.
//
// Параметры:
//  Ссылка - ЛюбаяСсылка - ссылка на объект информационной базы.
//
// Возвращаемое значение:
//  Строка - UUID или пустая строка.
//
Функция УникальныйИдентификаторСсылки(Ссылка) Экспорт
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Строка(Ссылка.УникальныйИдентификатор());
	
КонецФункции

// Проверяет, что номер телефона принадлежит пользователю информационной базы 1С.
//
// Параметры:
//  НомерТелефона - Строка - номер в любом пользовательском формате.
//
// Возвращаемое значение:
//  Структура - allowed, userRef, userName, login; employeeRef/employeeName — алиасы для совместимости.
//
Функция ПроверитьАвторизациюПоТелефону(НомерТелефона) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("allowed", Ложь);
	Результат.Вставить("userRef", "");
	Результат.Вставить("userName", "");
	Результат.Вставить("login", "");
	Результат.Вставить("employeeRef", "");
	Результат.Вставить("employeeName", "");
	Результат.Вставить("personRef", "");
	Результат.Вставить("personName", "");
	
	Если Не ЗначениеЗаполнено(СокрЛП(НомерТелефона)) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТолькоЦифрыТелефона(НомерТелефона)) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Пользователь = НайтиПользователяПоТелефону(НомерТелефона);
	Если Не ЗначениеЗаполнено(Пользователь) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Пользователь, "Наименование");
	
	Результат.allowed = Истина;
	Результат.userRef = УникальныйИдентификаторСсылки(Пользователь);
	Результат.userName = Реквизиты.Наименование;
	Результат.login = Реквизиты.Наименование;
	Результат.employeeRef = Результат.userRef;
	Результат.employeeName = Результат.userName;
	
	Возврат Результат;
	
КонецФункции

