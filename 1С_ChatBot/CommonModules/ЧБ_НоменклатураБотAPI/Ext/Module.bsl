
#Область ПрограммныйИнтерфейс

// Выполняет поиск номенклатуры по строке (разбивает на токены, каскадный поиск).
//
// Параметры:
//  СтрокаПоиска - Строка - фрагмент для поиска.
//  Лимит - Число - максимальное число результатов.
//
// Возвращаемое значение:
//  Структура - поле items содержит массив структур ref, name, article, barcode, score.
//
Функция ПоискНоменклатуры(СтрокаПоиска, Лимит = 5) Экспорт
	
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("barcode", "");
	ПараметрыПоиска.Вставить("article", "");
	ПараметрыПоиска.Вставить("tokens", Новый Массив);
	ПараметрыПоиска.Вставить("q", "");
	
	Если Не ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Возврат Новый Структура("items", Новый Массив);
	КонецЕсли;
	
	НормализованнаяСтрока = НормализоватьСтрокуПоиска(СтрокаПоиска);
	Если ПохожеНаШтрихкод(НормализованнаяСтрока) Тогда
		ПараметрыПоиска.barcode = ТолькоЦифрыШтрихкода(НормализованнаяСтрока);
	Иначе
		ПараметрыПоиска.tokens = РазложитьСтрокуНаТокены(НормализованнаяСтрока);
		Если ПараметрыПоиска.tokens.Количество() = 0 Тогда
			ПараметрыПоиска.q = НормализованнаяСтрока;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПоискНоменклатурыРасширенный(ПараметрыПоиска, Лимит);
	
КонецФункции

// Каскадный поиск: штрихкод → артикул → ключевые слова с ранжированием.
//
// Параметры:
//  ПараметрыПоиска - Структура - barcode, article, tokens (массив), q.
//  Лимит - Число - максимальное число результатов.
//
// Возвращаемое значение:
//  Структура - поле items содержит массив структур ref, name, article, barcode, score.
//
Функция ПоискНоменклатурыРасширенный(ПараметрыПоиска, Лимит = 5) Экспорт
	
	Результат = Новый Структура("items", Новый Массив);
	ЛимитВыборки = Макс(1, Мин(Лимит, 50));
	Кандидаты = Новый Соответствие;
	
	Штрихкод = "";
	Артикул = "";
	Токены = Новый Массив;
	СтрокаПоиска = "";
	
	Если ТипЗнч(ПараметрыПоиска) = Тип("Структура") Тогда
		Если ПараметрыПоиска.Свойство("barcode") Тогда
			Штрихкод = ТолькоЦифрыШтрихкода(ПараметрыПоиска.barcode);
		КонецЕсли;
		Если ПараметрыПоиска.Свойство("article") Тогда
			Артикул = НормализоватьСтрокуПоиска(ПараметрыПоиска.article);
		КонецЕсли;
		Если ПараметрыПоиска.Свойство("tokens") И ТипЗнч(ПараметрыПоиска.tokens) = Тип("Массив") Тогда
			Токены = ПараметрыПоиска.tokens;
		КонецЕсли;
		Если ПараметрыПоиска.Свойство("q") Тогда
			СтрокаПоиска = НормализоватьСтрокуПоиска(ПараметрыПоиска.q);
		КонецЕсли;
	ИначеЕсли ТипЗнч(ПараметрыПоиска) = Тип("Соответствие") Тогда
		Штрихкод = ТолькоЦифрыШтрихкода(ПараметрыПоиска.Получить("barcode"));
		Артикул = НормализоватьСтрокуПоиска(ПараметрыПоиска.Получить("article"));
		ТокеныЗначение = ПараметрыПоиска.Получить("tokens");
		Если ТипЗнч(ТокеныЗначение) = Тип("Массив") Тогда
			Токены = ТокеныЗначение;
		КонецЕсли;
		СтрокаПоиска = НормализоватьСтрокуПоиска(ПараметрыПоиска.Получить("q"));
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Штрихкод) И Не ЗначениеЗаполнено(Артикул)
		И Токены.Количество() = 0 И Не ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Штрихкод) Тогда
		ДобавитьКандидатовПоШтрихкоду(Кандидаты, Штрихкод, 100);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Артикул) Тогда
		ДобавитьКандидатовПоАртикулу(Кандидаты, Артикул, 80, 60);
	КонецЕсли;
	
	НормализованныеТокены = НормализоватьМассивТокенов(Токены);
	Если НормализованныеТокены.Количество() > 0 Тогда
		ДобавитьКандидатовПоТокенам(Кандидаты, НормализованныеТокены);
	КонецЕсли;
	
	Если Кандидаты.Количество() = 0 И ЗначениеЗаполнено(СтрокаПоиска) Тогда
		ТокеныИзСтроки = РазложитьСтрокуНаТокены(СтрокаПоиска);
		Если ТокеныИзСтроки.Количество() > 0 Тогда
			ДобавитьКандидатовПоТокенам(Кандидаты, ТокеныИзСтроки);
		Иначе
			ДобавитьКандидатовПоПодстроке(Кандидаты, СтрокаПоиска, 15);
		КонецЕсли;
	КонецЕсли;
	
	Результат.items = СформироватьСписокКандидатов(Кандидаты, ЛимитВыборки);
	Возврат Результат;
	
КонецФункции

// Возвращает остатки номенклатуры по регистру Запасы.
//
// Параметры:
//  СсылкаНоменклатуры - СправочникСсылка.Номенклатура - номенклатура.
//  Склад - Строка - UUID или наименование структурной единицы; пустая строка — все склады.
//
// Возвращаемое значение:
//  Структура - quantity, warehouse, items.
//
Функция ПолучитьОстатки(СсылкаНоменклатуры, Склад = "") Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("quantity", 0);
	Результат.Вставить("warehouse", "");
	Результат.Вставить("items", Новый Массив);
	
	Если Не ЗначениеЗаполнено(СсылкаНоменклатуры) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтруктурнаяЕдиница = Неопределено;
	Если ЗначениеЗаполнено(Склад) Тогда
		СтруктурнаяЕдиница = НайтиСтруктурнуюЕдиницу(Склад);
	КонецЕсли;
	
	ТекстУсловия = "Номенклатура = &Номенклатура
		|	И ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
		|	И ТИПЗНАЧЕНИЯ(СтруктурнаяЕдиница) = ТИП(Справочник.СтруктурныеЕдиницы)";
	
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		ТекстУсловия = ТекстУсловия + "
		|	И СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(
		"ВЫБРАТЬ
		|	ЗапасыОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ЗапасыОстатки.Характеристика КАК Характеристика,
		|	СУММА(ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0)) КАК Количество
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(
		|			,
		|			%1) КАК ЗапасыОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстатки.СтруктурнаяЕдиница,
		|	ЗапасыОстатки.Характеристика
		|
		|ИМЕЮЩИЕ
		|	СУММА(ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0)) <> 0",
		ТекстУсловия);
	
	Запрос.УстановитьПараметр("Номенклатура", СсылкаНоменклатуры);
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		Результат.warehouse = Строка(СтруктурнаяЕдиница);
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Элемент = Новый Структура;
		Элемент.Вставить("warehouse", Строка(Выборка.СтруктурнаяЕдиница));
		Элемент.Вставить("characteristic", Строка(Выборка.Характеристика));
		Элемент.Вставить("quantity", Выборка.Количество);
		Результат.items.Добавить(Элемент);
		Результат.quantity = Результат.quantity + Выборка.Количество;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает реквизиты номенклатуры, цену и характеристики.
//
// Параметры:
//  СсылкаНоменклатуры - СправочникСсылка.Номенклатура - номенклатура.
//
// Возвращаемое значение:
//  Структура - name, article, barcode, unit, price, priceType, characteristics.
//
Функция ПолучитьДетали(СсылкаНоменклатуры) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("name", "");
	Результат.Вставить("article", "");
	Результат.Вставить("barcode", "");
	Результат.Вставить("unit", "");
	Результат.Вставить("price", 0);
	Результат.Вставить("priceType", "");
	Результат.Вставить("prices", Новый Массив);
	Результат.Вставить("hasImage", Ложь);
	Результат.Вставить("characteristics", Новый Массив);
	
	Если Не ЗначениеЗаполнено(СсылкаНоменклатуры) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		СсылкаНоменклатуры,
		"Наименование, Артикул, Штрихкод, ЕдиницаИзмерения, ФайлКартинки");
	
	Результат.name = Реквизиты.Наименование;
	Результат.article = Реквизиты.Артикул;
	Результат.barcode = Реквизиты.Штрихкод;
	Результат.unit = Строка(Реквизиты.ЕдиницаИзмерения);
	Результат.hasImage = ЗначениеЗаполнено(Реквизиты.ФайлКартинки);
	
	Попытка
		
		ЗапросЦен = Новый Запрос;
	ЗапросЦен.Текст =
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.ВидЦен.Наименование КАК ВидЦен,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
		|	ПРЕДСТАВЛЕНИЕ(ЦеныНоменклатурыСрезПоследних.Характеристика) КАК Характеристика,
		|	ЦеныНоменклатурыСрезПоследних.ВалютаЦены.Наименование КАК Валюта,
		|	ПРЕДСТАВЛЕНИЕ(ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения) КАК ЕдиницаИзмерения
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			,
		|			Номенклатура = &Номенклатура
		|				И Актуальность = ИСТИНА) КАК ЦеныНоменклатурыСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидЦен";
	
	ЗапросЦен.УстановитьПараметр("Номенклатура", СсылкаНоменклатуры);
	
	ВыборкаЦен = ЗапросЦен.Выполнить().Выбрать();
	Пока ВыборкаЦен.Следующий() Цикл
		
		ЭлементЦены = Новый Структура;
		ЭлементЦены.Вставить("priceType", ВыборкаЦен.ВидЦен);
		ЭлементЦены.Вставить("price", ВыборкаЦен.Цена);
		ЭлементЦены.Вставить("characteristic", ВыборкаЦен.Характеристика);
		ЭлементЦены.Вставить("currency", ВыборкаЦен.Валюта);
		ЭлементЦены.Вставить("unit", ВыборкаЦен.ЕдиницаИзмерения);
		Результат.prices.Добавить(ЭлементЦены);
		
		Если Результат.price = 0 Тогда
			Результат.price = ВыборкаЦен.Цена;
			Результат.priceType = ВыборкаЦен.ВидЦен;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Результат.price = 0 Тогда
		
		ВидЦен = Справочники.ВидыЦен.ПолучитьОсновнойВидЦенПродажи();
		Если ЗначениеЗаполнено(ВидЦен) Тогда
			Результат.priceType = Строка(ВидЦен);
		КонецЕсли;
		
	КонецЕсли;
		
	Исключение
		// Ошибка цен не должна блокировать характеристики.
	КонецПопытки;
	
	ЗапросХарактеристик = Новый Запрос;
	ЗапросХарактеристик.Текст =
		"ВЫБРАТЬ
		|	Характеристики.Ссылка КАК Ссылка,
		|	Характеристики.Наименование КАК Наименование,
		|	Характеристики.Артикул КАК Артикул
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК Характеристики
		|ГДЕ
		|	Характеристики.Владелец = &Номенклатура
		|	И НЕ Характеристики.ПометкаУдаления
		|	И НЕ Характеристики.Недействителен
		|
		|УПОРЯДОЧИТЬ ПО
		|	Характеристики.Наименование";
	
	ЗапросХарактеристик.УстановитьПараметр("Номенклатура", СсылкаНоменклатуры);
	
	ВыборкаХарактеристик = ЗапросХарактеристик.Выполнить().Выбрать();
	Пока ВыборкаХарактеристик.Следующий() Цикл
		
		Характеристика = Новый Структура;
		Характеристика.Вставить("ref", УникальныйИдентификаторСсылки(ВыборкаХарактеристик.Ссылка));
		Характеристика.Вставить("name", ВыборкаХарактеристик.Наименование);
		Характеристика.Вставить("article", ВыборкаХарактеристик.Артикул);
		Результат.characteristics.Добавить(Характеристика);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает двоичные данные картинки номенклатуры из присоединённого файла.
//
// Параметры:
//  СсылкаНоменклатуры - СправочникСсылка.Номенклатура - номенклатура.
//
// Возвращаемое значение:
//  Структура - found, mimeType, data.
//
Функция ПолучитьДвоичныеДанныеКартинки(СсылкаНоменклатуры) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("found", Ложь);
	Результат.Вставить("mimeType", "application/octet-stream");
	Результат.Вставить("data", Неопределено);
	
	Если Не ЗначениеЗаполнено(СсылкаНоменклатуры) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНоменклатуры, "ФайлКартинки");
	ФайлКартинки = Реквизиты.ФайлКартинки;
	Если Не ЗначениеЗаполнено(ФайлКартинки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДвоичныеДанные = Неопределено;
	Попытка
		ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(ФайлКартинки, Ложь);
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	Если ДвоичныеДанные = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	РеквизитыФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ФайлКартинки, "Расширение");
	Результат.found = Истина;
	Результат.mimeType = ТипСодержимогоПоРасширению(РеквизитыФайла.Расширение);
	Результат.data = ДвоичныеДанные;
	
	Возврат Результат;
	
КонецФункции

// Возвращает ссылку на объект метаданных по строковому UUID.
//
// Параметры:
//  СтрокаUUID - Строка - уникальный идентификатор ссылки.
//  ИмяМетаданных - Строка - полное имя метаданных, например Справочник.Номенклатура.
//
// Возвращаемое значение:
//  ЛюбаяСсылка, Неопределено - ссылка или Неопределено, если UUID некорректен.
//
Функция СсылкаПоУникальномуИдентификатору(СтрокаUUID, ИмяМетаданных = "Справочник.Номенклатура") Экспорт
	
	Если Не ЗначениеЗаполнено(СтрокаUUID) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		УникальныйИдентификатор = Новый УникальныйИдентификатор(СтрокаUUID);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Менеджер = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяМетаданных);
	Возврат Менеджер.ПолучитьСсылку(УникальныйИдентификатор);
	
КонецФункции

// Сериализует значение в JSON-строку.
//
// Параметры:
//  Значение - Произвольный - структура, массив или примитив для записи.
//
// Возвращаемое значение:
//  Строка - JSON.
//
Функция ЗаписатьJSONВСтроку(Знач Значение) Экспорт
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Десериализует JSON-строку в структуру или соответствие.
//
// Параметры:
//  СтрокаJSON - Строка - JSON для чтения.
//  ВернутьСоответствие - Булево - Истина для соответствия, Ложь для структуры.
//
// Возвращаемое значение:
//  Структура, Соответствие - разобранные данные.
//
Функция ПрочитатьJSONИзСтроки(СтрокаJSON, ВернутьСоответствие = Истина) Экспорт
	
